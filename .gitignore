# ============================================================
#  EduChrono — .gitignore
# ============================================================

# ------ Environment & Secrets (NEVER commit these) ----------
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
config/secrets.*
secrets.*

# ------ PHP files with hardcoded API keys -------------------
educhrono-backend/app/templates/Views/questionnaire copy.php
educhrono-backend/app/templates/Views/questionnaire copy 2.php

# ------ Python -----------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*$py.class
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.eggs/

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Python logs & databases
*.log
*.sqlite
*.sqlite3
*.db

# Jupyter
.ipynb_checkpoints/

# ------ Node / React / Vite ----------------------------------
node_modules/
dist/
build/
.cache/
.parcel-cache/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Lock files (keep package-lock.json but ignore yarn.lock if unused)
yarn.lock

# ------ Editor & OS ------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# ------ Misc project files -----------------------------------
Full_Timetable.docx
*.docx
*.zip
*.tar.gz
